FROM --platform=$BUILDPLATFORM golang:1.25-bookworm AS build
ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build -trimpath -ldflags="-s -w -X main.version=${VERSION}" -o /out/avdctl ./cmd/avdctl

FROM dhi.io/static:latest
COPY --from=build --chown=65532:65532 /out/avdctl /usr/local/bin/avdctl
USER 65532:65532
ENTRYPOINT ["/usr/local/bin/avdctl"]
